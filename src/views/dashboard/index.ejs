<%
var body = `
<div class="container">
  <h1>${t('dashboard.title')}</h1>

  <div class="create-buttons">
    <a href="/dashboard/create?type=quiz" class="btn-create quiz">${t('session.quiz')}</a>
    <a href="/dashboard/create?type=poll" class="btn-create poll">${t('session.poll')}</a>
    <a href="/dashboard/create?type=wordcloud" class="btn-create wordcloud">${t('session.wordcloud')}</a>
  </div>

  ${sessions.length === 0 ? `
    <div class="empty-state">
      <p>${t('dashboard.noSessions')}</p>
    </div>
  ` : `
    <div class="sessions-list">
      ${sessions.map(session => `
        <div class="session-item">
          <div class="session-info">
            <h3>${session.title}</h3>
            <div class="badges">
              <span class="badge type ${session.type}">${t('session.' + session.type)}</span>
              <span class="badge status ${session.status}">${t('session.' + session.status)}</span>
            </div>
            <p class="created-date">Created: ${new Date(session.createdAt).toLocaleDateString()}</p>
            <p class="participant-link">
              Participant Link:
              <input type="text" value="${req.protocol}://${req.get('host')}/s/${session.id}" readonly id="link-${session.id}">
              <button onclick="copyToClipboard('${req.protocol}://${req.get('host')}/s/${session.id}')">Copy</button>
            </p>
          </div>
          <div class="session-actions">
            <a href="/dashboard/session/${session.id}" class="btn-view">View Results</a>
            ${session.status === 'open' ? `
              <form method="POST" action="/dashboard/session/${session.id}/close" style="display: inline;">
                <button type="submit" class="btn-close">${t('session.close')}</button>
              </form>
            ` : ''}
            <form method="POST" action="/dashboard/session/${session.id}/delete" style="display: inline;">
              <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this session?')">${t('session.delete')}</button>
            </form>
          </div>
        </div>
      `).join('')}
    </div>
  `}
</div>

<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(() => {
    alert('Link copied to clipboard!');
  }).catch(err => {
    console.error('Failed to copy: ', err);
  });
}
</script>
`
%>
<%- include('../layout/base') %>