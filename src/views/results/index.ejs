<%
var body = `
<div class="container">
  <div class="session-header">
    <h1><%= session.title %></h1>
    <div class="session-meta">
      <span class="badge type <%= session.type %>"><%= t('session.' + session.type) %></span>
      <span class="badge status <%= session.status %>"><%= t('session.' + session.status) %></span>
      <span class="responses-count">Responses: <span id="total-responses"><%= session.responses.length %></span></span>
    </div>
  </div>

  <div class="participant-link">
    <label>Participant Link:</label>
    <input type="text" value="${req.protocol}://${req.get('host')}/s/<%= session.id %>" readonly id="link-input">
    <button onclick="copyToClipboard('${req.protocol}://${req.get('host')}/s/<%= session.id %>')">Copy</button>
  </div>

  <div class="session-controls">
    <% if (session.status === 'open') { %>
      <form method="POST" action="/dashboard/session/<%= session.id %>/close" style="display: inline;">
        <button type="submit" class="btn-close"><%= t('session.close') %></button>
      </form>
    <% } %>
    <form method="POST" action="/dashboard/session/<%= session.id %>/delete" style="display: inline;">
      <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this session?')"><%= t('session.delete') %></button>
    </form>
  </div>

  <div id="results-content">
    ${session.type === 'wordcloud' ? `
      <div class="wordcloud-container">
        <canvas id="wc" width="800" height="400"></canvas>
      </div>
    ` : `
      <div class="questions-results">
        ${session.config.questions.map((question, qIndex) => `
          <div class="question-result" data-question-index="${qIndex}">
            <h3>${question.text}</h3>
            <div class="bars">
              ${question.options.map((option, oIndex) => {
                const count = session.responses.filter(r => 'answers' in r && r.answers[qIndex] === oIndex).length;
                const percentage = session.responses.length > 0 ? (count / session.responses.length * 100).toFixed(1) : '0';
                const isCorrect = session.type === 'quiz' && 'correct' in question && question.correct === oIndex;
                return `
                  <div class="bar-container">
                    <div class="bar ${isCorrect ? 'correct' : ''}" style="width: ${percentage}%">
                      <span class="bar-label">${option}</span>
                      <span class="bar-value">${count} (${percentage}%)</span>
                    </div>
                  </div>
                `;
              }).join('')}
            </div>
          </div>
        `).join('')}
      </div>
    `}
  </div>

  <div class="back-link">
    <a href="/dashboard">← Back to Dashboard</a>
  </div>
</div>

${session.type === 'wordcloud' ? '<script src="https://cdn.jsdelivr.net/npm/wordcloud@1.2.2/src/wordcloud2.js"></script>' : ''}

<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(() => {
    alert('Link copied to clipboard!');
  }).catch(err => {
    console.error('Failed to copy: ', err);
  });
}

window.SESSION_ID = '<%= session.id %>';
window.SESSION_TYPE = '<%= session.type %>';
</script>
`
%>
<%- include('../layout/base') %>
