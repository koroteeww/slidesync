<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= session.title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="container">
    <h1><%= session.title %></h1>
    <p><%= session.config.prompt %></p>

    <form id="wordcloudForm">
      <div>
        <label for="word">Your word or phrase:</label>
        <input type="text" id="word" name="word" required maxlength="100">
      </div>

      <button type="submit">Submit</button>
    </form>

    <div id="message"></div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    const SESSION_ID = '<%= session.id %>';

    document.getElementById('wordcloudForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const word = document.getElementById('word').value.trim();

      try {
        const response = await fetch(`/s/${SESSION_ID}/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            participantId: getParticipantId(),
            word,
          }),
        });

        const result = await response.json();

        if (result.ok) {
          document.getElementById('message').textContent = 'Submitted successfully!';
          e.target.style.display = 'none';
        } else {
          document.getElementById('message').textContent = result.error;
        }
      } catch (error) {
        document.getElementById('message').textContent = 'Error submitting';
      }
    });
  </script>
</body>
</html>
