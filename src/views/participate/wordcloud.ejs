<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= session.title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="container">
    <h1><%= session.title %></h1>
    <p><%= session.config.prompt %></p>

    <form id="wordcloudForm">
      <div>
        <label for="word">Your word or phrase:</label>
        <input type="text" id="word" name="word" required maxlength="100">
      </div>

      <div style="text-align:center; margin-top:1rem;">
        <button id="submitBtn" type="button"><%= t('participate.submit') %></button>
      </div>
    </form>

    <div id="thankyou" style="display:none; text-align:center; margin-top:1.5rem;">
      <p><%= t('participate.wordAdded') %></p>
    </div>

    <div class="wordcloud-container">
      <canvas id="wc" width="800" height="400"></canvas>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/wordcloud@1.2.2/src/wordcloud2.js"></script>
  <script>
    window.SESSION_ID = '<%= session.id %>';
    window.SESSION_TYPE = '<%= session.type %>';

    async function submitWord(){
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      const word = document.getElementById('word').value.trim();
      try{
        const res = await fetch(`/s/${SESSION_ID}/submit`, {
          method: 'POST', headers: { 'Content-Type':'application/json' },
          body: JSON.stringify({ participantId: localStorage.getItem('participantId') || '', word })
        });
        const data = await res.json();
        if(res.ok){
          document.getElementById('wordcloudForm').style.display = 'none';
          document.getElementById('thankyou').style.display = 'block';
        } else { alert(data.error || 'Submit failed'); btn.disabled = false; }
      } catch(err){ console.error(err); alert('Submission error'); btn.disabled = false; }
    }

    document.getElementById('submitBtn').addEventListener('click', submitWord);

    // Poll results and render cloud
    async function fetchResults(){
      try{
        const res = await fetch('/api/results/' + SESSION_ID);
        if(!res.ok) return null;
        return await res.json();
      } catch(e){ return null; }
    }

    function renderCloud(words){
      const list = words.map(w => [w.text, w.count]);
      const canvas = document.getElementById('wc');
      if(typeof WordCloud !== 'undefined' && canvas){
        WordCloud(canvas, { list, gridSize: Math.round(16 * canvas.width / 1024), weightFactor: 2, rotateRatio: 0.5 });
      }
    }

    async function pollCloud(){
      const data = await fetchResults();
      if(data && data.type === 'wordcloud'){
        renderCloud(data.words || []);
      }
    }

    // start polling every 500ms
    setInterval(pollCloud, 500);
    // initial render
    pollCloud();
  </script>
</body>
</html>
