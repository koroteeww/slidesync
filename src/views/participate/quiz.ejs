<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= session.title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="container">
    <h1><%= session.title %></h1>

    <form id="quizForm">
      <% session.config.questions.forEach(question => { %>
        <div class="question">
          <h3><%= question.text %></h3>
          <% question.options.forEach((option, index) => { %>
            <label>
              <input type="radio" name="answers[<%= question.id %>]" value="<%= index %>" required>
              <%= option %>
            </label>
          <% }); %>
        </div>
      <% }); %>

      <div style="text-align:center; margin-top:1rem;">
        <button id="submitBtn" type="button"><%= t('participate.submit') %></button>
      </div>
    </form>

    <div id="thankyou" style="display:none; text-align:center; margin-top:1.5rem;">
      <p><%= t('participate.submitted') %></p>
      <p id="score" style="font-weight:bold; display:none;"></p>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    window.SESSION_ID = '<%= session.id %>';
    window.SESSION_TYPE = '<%= session.type %>';
    window.SESSION_CONFIG = <%- JSON.stringify(session.config) %>;

    function collectAnswers(){
      const form = document.getElementById('quizForm');
      const inputs = form.querySelectorAll('input[type=radio]:checked');
      const answers = {};
      inputs.forEach(i => {
        const m = i.name.match(/^answers\[(\d+)\]/) || i.name.match(/^q_(\d+)$/);
        if(m) answers[m[1]] = Number(i.value);
      });
      return answers;
    }

    async function submitAnswers(){
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      const answers = collectAnswers();

      try{
        const res = await fetch(`/s/${SESSION_ID}/submit`, {
          method: 'POST', headers: { 'Content-Type':'application/json' },
          body: JSON.stringify({ participantId: localStorage.getItem('participantId') || '', answers })
        });
        const data = await res.json();
        if(res.ok){
          document.getElementById('quizForm').style.display = 'none';
          document.getElementById('thankyou').style.display = 'block';
          // compute score locally using SESSION_CONFIG
          if(SESSION_CONFIG && Array.isArray(SESSION_CONFIG.questions)){
            let correct = 0, total = SESSION_CONFIG.questions.length;
            for(const q of SESSION_CONFIG.questions){
              const ans = answers[q.id];
              if(typeof q.correct === 'number' && ans === q.correct) correct++;
            }
            const scoreEl = document.getElementById('score');
            scoreEl.textContent = `${correct} ${'<%= t('participate.outOf') %>'} ${total}`;
            scoreEl.style.display = 'block';
          }
        } else {
          alert(data.error || 'Submit failed');
          btn.disabled = false;
        }
      } catch(err){
        console.error(err); alert('Submission error'); btn.disabled = false;
      }
    }

    document.getElementById('submitBtn').addEventListener('click', submitAnswers);
  </script>
</body>
</html>
